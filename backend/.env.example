# NursePath Backend — environment variables
# Copy this file to .env and fill in real values.

# ── Database ──────────────────────────────────────────────────────────────
# Local dev (SQLite):  file:./dev.db
# Production (Neon):   postgresql://user:pass@host/db?sslmode=require
DATABASE_URL="file:./dev.db"

# ── Authentication ────────────────────────────────────────────────────────
# Generate a strong 32+ char random string for production:
#   openssl rand -base64 32
JWT_SECRET="dev-secret-change-me"

# ── Server ────────────────────────────────────────────────────────────────
PORT=4000

# ── CORS ──────────────────────────────────────────────────────────────────
# The deployed frontend origin. Set to your Vercel URL in production.
#   https://nursepath.vercel.app
FRONTEND_ORIGIN="http://localhost:5173"

# ── Environment ───────────────────────────────────────────────────────────
# Set to "production" when deploying
NODE_ENV="development"
