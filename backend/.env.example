# NursePath Backend — environment variables
# Copy this file to .env and fill in real values.

# ── Database ──────────────────────────────────────────────────────────────
# Local dev (SQLite):  file:./dev.db
# Production (Neon):   postgresql://user:pass@host/db?sslmode=require
DATABASE_URL="file:./dev.db"

# ── Authentication ────────────────────────────────────────────────────────
# Generate a strong 32+ char random string for production:
#   openssl rand -base64 32
JWT_SECRET="dev-secret-change-me"

# ── Server ────────────────────────────────────────────────────────────────
PORT=4000

# ── CORS ──────────────────────────────────────────────────────────────────
# The deployed frontend origin. Set to your Vercel URL in production.
#   https://nursepath.vercel.app
FRONTEND_ORIGIN="http://localhost:5173"

# ── Environment ───────────────────────────────────────────────────────────
# Set to "production" when deploying
NODE_ENV="development"

# ── Email (Resend) ────────────────────────────────────────────────────────
# Get a free API key at https://resend.com (100 emails/day free)
RESEND_API_KEY="re_..."
# Full URL to the frontend verify page (without ?token=...)
VERIFY_URL="http://localhost:5173/verify"

# ── Google OAuth ──────────────────────────────────────────────────────────
# Get a Client ID at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
